# ===========================================
# LIRIEL AGENT - Easypanel Environment Variables
# ===========================================
# Configure these in: Easypanel → Project → liriel-agent → Environment
#
# Setup no Easypanel (mesmo projeto, 3 serviços):
#   1. liriel-postgres  → Postgres 16 (database service)
#   2. liriel-redis     → Redis 7 (database service)  
#   3. liriel-agent     → App (docker service, este Dockerfile)
#
# Os hostnames abaixo usam o nome do serviço no Easypanel.
# Ajuste se você usar nomes diferentes.
# ===========================================

# --- PostgreSQL ---
# Hostname = nome do serviço postgres no Easypanel
DATABASE_URL=postgresql+asyncpg://liriel:SUA_SENHA_SEGURA@liriel-postgres:5432/liriel_db

# --- Redis ---
# Hostname = nome do serviço redis no Easypanel
REDIS_URL=redis://liriel-redis:6379/0

# --- OpenAI ---
OPENAI_API_KEY=sk-sua-chave-openai
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1024

# --- Uazapi v2 ---
UAZAPI_BASE_URL=https://sua-uazapi.com
UAZAPI_API_KEY=token-da-sua-instancia

# --- Message Buffer ---
BUFFER_DELAY_SECONDS=12
MAX_HISTORY_MESSAGES=20

# --- App ---
LOG_LEVEL=INFO
APP_PORT=8000
